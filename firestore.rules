rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // "leads" collection — written by contact form, read only via Firebase Console
    match /leads/{docId} {
      allow write: if validateLead(request.resource.data);
      allow read:  if false; // Admin only via Firebase Console
    }

    // Block everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

function validateLead(data) {
  return data.keys().hasAll(['name', 'email', 'phone', 'message'])
    && data.name    is string && data.name.size()    > 0 && data.name.size()    < 200
    && data.email   is string && data.email.matches('.*@.*\\..*')
    && data.phone   is string && data.phone.size()   > 0 && data.phone.size()   < 25
    && data.message is string && data.message.size() > 0 && data.message.size() < 3000;
}
